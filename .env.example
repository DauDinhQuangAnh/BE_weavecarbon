# Environment variables
PORT=4000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=weavecarbon
DB_USER=postgres
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration - Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=your_email@gmail.com

# Frontend URL
FRONTEND_URL=https://weavecarbon.com
FRONTEND_URLS=https://weavecarbon.com,https://www.weavecarbon.com,http://localhost:3000,http://127.0.0.1:3000

# RAG proxy allowlist for chat history feature
RAG_PROXY_ALLOWED_BASE_URLS=http://127.0.0.1:8000,http://localhost:8000

# Public backend URL for links sent via email
AUTH_PUBLIC_BASE_URL=https://unescutcheoned-fervid-sylvia.ngrok-free.dev

# VNPay Configuration
# mode: mock | sandbox | production
# - mock: local test, no merchant credentials needed
# - sandbox/production: requires VNPAY_TMN_CODE and VNPAY_HASH_SECRET
VNPAY_MODE=sandbox
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://unescutcheoned-fervid-sylvia.ngrok-free.dev/api/subscription/vnpay/return
VNPAY_IPN_URL=https://unescutcheoned-fervid-sylvia.ngrok-free.dev/api/subscription/vnpay/ipn

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://unescutcheoned-fervid-sylvia.ngrok-free.dev/api/auth/google/callback

# CORS
CORS_ORIGIN=https://weavecarbon.com,https://www.weavecarbon.com,http://localhost:3000,http://127.0.0.1:3000

# Runtime tuning
EXPORT_JOB_CONCURRENCY=1
READ_CACHE_TTL_MS=30000
SLOW_REQUEST_MS=500
# Optional: override uploads location outside the release directory
# UPLOADS_DIR=/var/lib/weavecarbon/uploads
